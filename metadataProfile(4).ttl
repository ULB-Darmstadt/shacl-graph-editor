	dcterms:title "m4i Sample"@en, "m4i Probe"@de ;
	a rdfs:Class, sh:NodeShape ;
	sh:closed false ;
	sh:property [
		sh:name "Label"@en, "Bezeichnung"@de ;
		sh:path rdfs:label ;
		sh:order 1 ;
		sh:datatype xsd:string ;
		sh:maxCount 1 ;
		sh:minCount 1 ;
		dash:singleLine true ;
	], [
		sh:name "Beschreibung"@de, "Description"@en ;
		sh:path dcterms:description ;
		sh:order 2 ;
		sh:datatype xsd:string ;
		sh:maxCount 1 ;
		dash:singleLine false ;
	], [
		sh:name "sample ID"@en, "Proben ID"@de ;
		sh:path schema:identifier ;
		sh:order 3 ;
		sh:datatype xsd:string ;
		sh:maxCount 1 ;
		sh:minCount 1 ;
	], [
		sh:name "Date Created"@en, "Erstellungsdatum"@de ;
		sh:path dcterms:created ;
		sh:order 4 ;
		sh:datatype xsd:dateTime ;
		sh:maxCount 1 ;
	] .

