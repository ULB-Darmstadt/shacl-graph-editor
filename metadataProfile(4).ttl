<https://w3id.org/nfdi4ing/profiles/70d2267e-369f-4aed-876d-82de8e9192db/> dcterms:created "2024-08-22"^^xsd:date ;
	dcterms:creator "Metadata4Ing" ;
	dcterms:description "Eine Variable, die einen Double oder Integer als Wert erwartet"@de, "A variable that expects a double or integer as value"@en ;
	dcterms:license <http://spdx.org/licenses/CC0-1.0> ;
	dcterms:title "m4i Numerische Variable"@de, "m4i Numerical Variable"@en ;
	a sh:NodeShape ;
	owl:imports <http://qudt.org/vocab/quantitykind>, <https://qudt.org/vocab/unit/>, <https://w3id.org/nfdi4ing/profiles/d7d86748-b7ec-448f-9e45-cb1a1fd26b7e/> ;
	sh:closed false ;
	sh:node <https://w3id.org/nfdi4ing/profiles/d7d86748-b7ec-448f-9e45-cb1a1fd26b7e/> ;
	sh:property [
		sh:name "Größenart"@de, "Quantity Kind"@en ;
		sh:path m4i:hasKindOfQuantity ;
		sh:order 1 ;
		sh:maxCount 1 ;
		sh:class qudt:QuantityKind ;
		sh:minCount 1 ;
	], [
		sh:name "Numerical Value"@en, "Numerischer Wert"@de ;
		sh:path m4i:hasNumericalValue ;
		sh:order 2 ;
		sh:maxCount 1 ;
		sh:minCount 1 ;
		sh:xone (
			[
				sh:datatype xsd:integer ;
				rdfs:label "Ganzzahl"@de, "Integer"@en ;
			]
			[
				sh:datatype xsd:double ;
				rdfs:label "Floating point"@en, "Fließkommazahl"@de ;
			]
		) ;
	], [
		sh:name "Unit"@en, "Einheit"@de ;
		sh:path m4i:hasUnit ;
		sh:order 3 ;
		sh:maxCount 1 ;
		sh:class qudt:Unit ;
		sh:minCount 1 ;
	] ;
	sh:targetClass m4i:NumericalVariable .

<https://w3id.org/nfdi4ing/profiles/122ec100-43a2-4d4c-a7a4-9bbddf214615/> dcterms:created "2025-12-12"^^xsd:date ;
	dcterms:creator "Metadata4Ing" ;
	dcterms:description "A binary variable that expects as a value either true or false."@en, "Eine binäre Variable, die als Wert entweder wahr oder falsch erwartet."@de ;
	dcterms:license <http://spdx.org/licenses/CC0-1.0> ;
	dcterms:title "m4i Boolesche Variable"@de, "m4i Boolean Variable"@en ;
	a rdfs:Class, sh:NodeShape ;
	owl:imports <https://w3id.org/nfdi4ing/profiles/d7d86748-b7ec-448f-9e45-cb1a1fd26b7e/> ;
	sh:closed false ;
	sh:node <https://w3id.org/nfdi4ing/profiles/d7d86748-b7ec-448f-9e45-cb1a1fd26b7e/> ;
	sh:property [
		sh:name "has boolean value"@en, "hat Booleschen Wert"@de ;
		sh:path m4i:hasBooleanValue ;
		sh:order 1 ;
		sh:datatype xsd:boolean ;
		sh:maxCount 1 ;
		sh:minCount 1 ;
		sh:description "A boolean value that can be true (expressed by 'true' or '1') or false (expressed by 'false' or '0')."@en, "Ein Boolescher Wert, der wahr (ausgedruckt durch 'true' oder '1') oder falsch (ausgedrückt durch 'false' oder '0') sein kann."@de ;
	] ;
	sh:targetClass m4i:BooleanVariable .

