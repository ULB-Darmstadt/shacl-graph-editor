<https://w3id.org/nfdi4ing/profiles/34c941c1-bf9e-425f-9be6-9a2c29c32dae/> dcterms:created "2024-08-06"^^xsd:date ;
	dcterms:creator "Metadata4Ing" ;
	dcterms:description "Abstrakte Beschreibung einer Methode zur Analyse, Erzeugung und Umwandlung von Daten und materiellen Objekten wie z. B. \"Fourier-Transform-Infrarotspektroskopie\" oder \"Molekulardynamiksimulation\". Beachten Sie, dass zwar Werte für relevante Parameter angegeben werden sollten, sich m4i:Method jedoch nicht auf die tatsächliche Ausführung des beschriebenen Prozesses bezieht (verwenden Sie dafür m4i:ProcessingStep), sondern eher eine Beschreibung des zugrunde liegenden Prinzips darstellt."@de, "Abstract description of a method for analysis, generation and transformation of data and material objects like, e.g., \"Fourier Transform Infrared Spectroscopy\" or \"Molecular Dynamics Simulation\". Note that while values for relevant parameters should be provided, m4i:Method does not refer to the actual execution of the process that is described (use m4i:ProcessingStep for that), but rather a description of the underlying principle."@en ;
	dcterms:license <http://spdx.org/licenses/CC0-1.0> ;
	dcterms:title "m4i Methode "@de, "m4i Method"@en ;
	a sh:NodeShape ;
	owl:imports <https://w3id.org/nfdi4ing/profiles/ab14d37c-cdf7-4f3d-aa58-b3baa450be15/> ;
	sh:closed false ;
	sh:property [
		sh:name "Label"@en, "Bezeichnung"@de ;
		sh:path rdfs:label ;
		sh:order 1 ;
		sh:datatype xsd:string ;
		sh:maxCount 1 ;
		sh:minCount 1 ;
		dash:singleLine true ;
	], [
		sh:name "Beschreibung"@de, "Description"@en ;
		sh:path dcterms:description ;
		sh:order 2 ;
		sh:datatype xsd:string ;
		sh:maxCount 1 ;
		dash:singleLine false ;
	], [
		sh:name "hat festen Parametersatz"@de, "has fixed parameter set"@en ;
		sh:path m4i:hasFixedParameterSet ;
		sh:qualifiedValueShape <https://w3id.org/nfdi4ing/profiles/ab14d37c-cdf7-4f3d-aa58-b3baa450be15/> ;
		sh:order 3 ;
		sh:qualifiedMaxCount 1 ;
	] ;
	sh:targetClass m4i:Method .

<https://w3id.org/nfdi4ing/profiles/d48f7be4-22d3-470a-b225-43f279a0bdb6/> dcterms:created "2025-06-18"^^xsd:date ;
