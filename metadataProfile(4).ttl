<https://w3id.org/nfdi4ing/profiles/7d380ae8-f46c-4698-8b44-22619872e0f4/> dcterms:created "2025-02-05"^^xsd:date ;
	dcterms:creator "Metadata4Ing" ;
	dcterms:description "Arbeitsschritt innerhalb eines wissenschaftlichen Prozesses"@de, "Specific action undertaken during research"@en ;
	dcterms:license <http://spdx.org/licenses/CC0-1.0> ;
	dcterms:title "m4i Arbeitsschritt"@de, "m4i Processing Step"@en ;
	a sh:NodeShape ;
	sh:closed false ;
	sh:property [
		sh:name "Beschreibung"@de, "Description"@en ;
		sh:path dcterms:description ;
		sh:order 1 ;
		sh:datatype xsd:string ;
		sh:maxCount 1 ;
	], [
		sh:name "has participant"@en, "hat Teilnehmer"@de ;
		sh:path <http://purl.obolibrary.org/obo/BFO_0000057> ;
		sh:order 2 ;
		sh:class prov:Agent ;
	], [
		sh:name "has start time"@en, "hat Startzeit"@de ;
		sh:path schema:startTime ;
		sh:order 3 ;
		sh:datatype xsd:dateTime ;
	], [
		sh:name "hat Endzeit"@de, "has end time"@en ;
		sh:path schema:endTime ;
		sh:order 4 ;
		sh:datatype xsd:dateTime ;
	], [
		sh:name "Label"@en, "Bezeichnung"@de ;
		sh:path rdfs:label ;
		sh:order 0 ;
		sh:datatype xsd:string ;
		sh:maxCount 1 ;
		sh:minCount 1 ;
	], [
		sh:name "immediately precedes"@en, "ist unmittelbare Voraussetzung für Schritt"@de ;
		sh:path <http://purl.obolibrary.org/obo/RO_0002090> ;
		sh:order 17 ;
		sh:maxCount 1 ;
		sh:class m4i:ProcessingStep ;
	], [
		sh:name "has part"@en, "hat Teil"@de ;
		sh:path <http://purl.obolibrary.org/obo/BFO_0000051> ;
		sh:order 13 ;
		sh:class m4i:ProcessingStep ;
	], [
		sh:name "starts with"@en, "beginnt mit"@de ;
		sh:path <http://purl.obolibrary.org/obo/RO_0002224> ;
		sh:order 14 ;
		sh:maxCount 1 ;
		sh:class m4i:ProcessingStep ;
	], [
		sh:name "ends with"@en, "endet mit"@de ;
		sh:path <http://purl.obolibrary.org/obo/RO_0002230> ;
		sh:order 15 ;
		sh:maxCount 1 ;
		sh:class m4i:ProcessingStep ;
	], [
		sh:name "ist Voraussetzung für Schritt"@de, "precedes"@en ;
		sh:path <http://purl.obolibrary.org/obo/BFO_0000063> ;
		sh:order 16 ;
		sh:class m4i:ProcessingStep ;
	], [
		sh:name "untersucht Eigenschaft"@de, "investigates property"@en ;
		sh:path m4i:investigatesProperty ;
		sh:order 9 ;
		sh:class <http://www.molmod.info/semantics/pims-ii.ttl#Property> ;
	], [
		sh:name "has parameter"@en, "hat Parameter"@de ;
		sh:path m4i:hasParameter ;
		sh:order 10 ;
		sh:class <http://www.molmod.info/semantics/pims-ii.ttl#Variable> ;
	], [
		sh:name "hat Input"@de, "has input"@en ;
		sh:path <http://purl.obolibrary.org/obo/RO_0002233> ;
		sh:order 11 ;
		sh:nodeKind sh:BlankNodeOrIRI ;
	], [
		sh:name "hat Output"@de, "has output"@en ;
		sh:path <http://purl.obolibrary.org/obo/RO_0002234> ;
		sh:order 12 ;
		sh:nodeKind sh:BlankNodeOrIRI ;
	], [
		sh:name "has employed tool"@en, "hat eingesetztes Werkzeug"@de ;
		sh:path m4i:hasEmployedTool ;
		sh:order 5 ;
		sh:class m4i:Tool ;
	], [
		sh:name "realisiert Methode"@de, "realizes method"@en ;
		sh:path m4i:realizesMethod ;
		sh:order 6 ;
		sh:class m4i:Method ;
	], [
		sh:name "uses configuration"@en, "benutzt Konfiguration"@de ;
		sh:path m4i:usesConfiguration ;
		sh:order 7 ;
		sh:class m4i:Configuration ;
	], [
		sh:name "untersucht"@de, "investigates"@en ;
		sh:path m4i:investigates ;
		sh:order 8 ;
	] ;
	sh:targetClass m4i:ProcessingStep .

<https://w3id.org/nfdi4ing/profiles/9257ff44-5c00-4773-bab8-d702c9a93d13/> dcterms:created "2025-07-07"^^xsd:date ;
