@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix aps: <https://w3id.org/nfdi4ing/profiles/> .

aps:0bbadc41-420e-4ea3-8090-83625c76ee1d
  dcterms:created "2026-07-08"^^xsd:date ;
  dcterms:creator "Roger Winkler" ;
  dcterms:description "ARDMP stakeholder node shape for organizations involved in a building project."@en ;
  dcterms:license <http://creativecommons.org/licenses/by/4.0/> ;
  dcterms:subject <https://github.com/tibonto/dfgfo/410-01> ;
  dcterms:title "ARDMP stakeholder"@en ;
  a sh:NodeShape ;
  rdfs:label "ARDMP stakeholder"@en ;
  owl:imports aps:9d3337fe-0375-485f-9b37-2782f53df7f8,
    aps:d5f4e2e0-ef67-4e45-b29f-29f2e4c63d0d ;
  sh:closed false ;
  sh:property [
    sh:order 1 ;
    sh:name "Label" ;
    sh:description "Label for the stakeholder."@en ;
    sh:path rdfs:label ;
  ], [
    sh:order 2 ;
    sh:name "Role" ;
    sh:description "Role of the stakeholder."@en ;
    sh:path dcat:hadRole ;
    sh:nodeKind sh:Literal ;
    sh:minCount 1 ;
  ], [
    sh:order 3 ;
    sh:name "Organization" ;
    sh:description "Organization acting as a stakeholder."@en ;
    sh:path prov:agent ;
    sh:nodeKind sh:IRI ;
    sh:node aps:9d3337fe-0375-485f-9b37-2782f53df7f8 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:targetClass prov:Attribution .