@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix gndo: <https://d-nb.info/standards/elementset/gnd#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix aps: <https://w3id.org/nfdi4ing/profiles/> .

aps:9db0f49d-72f5-4a7f-8436-7f6d57f3d312
  dcterms:created "2026-04-17"^^xsd:date ;
  dcterms:creator "Roger Winkler" ;
  dcterms:description "RO-kit collection dataset that contains a collection of one or multiple entity classes."@en ;
  dcterms:license <http://creativecommons.org/licenses/by/4.0/> ;
  dcterms:subject <https://github.com/tibonto/dfgfo/410-01> ;
  dcterms:title "RO-kit collection dataset"@en ;
  rdfs:label "RO-kit collection dataset"@en ;
  a rdfs:Class, sh:NodeShape ;
  owl:imports aps:4a5d4526-34d4-4b00-8f8f-4b13dd48e6d6 ;
  sh:closed false ;
  sh:node aps:4a5d4526-34d4-4b00-8f8f-4b13dd48e6d6 ;
  sh:property [
    sh:order 6 ;
    sh:name "Class partition" ;
    sh:description "Entity class and number of entities represented by a partition of a collection."@en ;
    sh:path void:classPartition ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node aps:9f821dd1-07b8-441b-93bd-ef120b3b6c5e ;
    sh:minCount 1 ;
  #], [
  #  sh:order 7 ;
  #  sh:name "Collection type" ;
  #  sh:description "Technical form of the collection."@en ;
  #  sh:path dcterms:type ;
  #  sh:datatype xsd:string ;
  #  sh:minCount 1 ;
  #  sh:maxCount 1 ;
  #  sh:in (
  #    "Table"
  #    "Database"
  #    "RDF"
  #  ) ;
  ] ;
  sh:targetClass dcat:Dataset .

aps:9f821dd1-07b8-441b-93bd-ef120b3b6c5e
  dcterms:created "2026-04-17"^^xsd:date ;
  dcterms:creator "Roger Winkler" ;
  dcterms:description "RO-kit nested node shape for class partitions in a collection dataset."@en ;
  dcterms:license <http://creativecommons.org/licenses/by/4.0/> ;
  dcterms:subject <https://github.com/tibonto/dfgfo/410-01> ;
  dcterms:title "RO-kit class partition node shape"@en ;
  a sh:NodeShape ;
  rdfs:label "RO-kit class partition"@en ;
  sh:closed false ;
  sh:property [
    sh:order 1 ;
    sh:name "Class" ;
    sh:description "Entity class represented by a partition of a collection."@en ;
    sh:path void:class ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in (
      aps:1f6323a9-b59b-4fb0-9f0f-63fd8ef9594a
    ) ;
  ], [
    sh:order 2 ;
    sh:name "Entities" ;
    sh:description "Number of entities represented by a partition of a collection."@en ;
    sh:path void:entities ;
    sh:datatype xsd:integer ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:minInclusive 1 ;
  ] ;
  sh:targetClass rdfs:Resource .
